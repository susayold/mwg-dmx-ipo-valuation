# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/
/_site/

# Python bytecode, environments and tool caches
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Local analytics/database state
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.db
*.db-journal
*.db-shm
*.db-wal

# Spreadsheet lock files and local scratch output
~$*.xlsx
~$*.docx
*.tmp

# Private preparation material is never part of the public portfolio
/private/
/interview/
/notes/
/docs/*Interview*
/docs/*INTERVIEW*

# Official filings are downloaded for local, non-commercial analysis only.
# Their source owners have not granted redistribution rights for this repository.
/data/raw/
# Local visual QA and TypeScript build cache
/.tmp_pdf_pages/
/.tmp_report_pages/
tsconfig.tsbuildinfo
